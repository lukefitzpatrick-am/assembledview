AUTH0_DOMAIN=auth.assembledview.com.au
AUTH0_BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH0_BASE_URL=http://localhost:3000
AUTH0_AUDIENCE=https://api.assembledview.com.au
# Reuse the same Auth0 application as production. Fill in the actual secrets.
AUTH0_CLIENT_ID=REPLACE_ME
AUTH0_CLIENT_SECRET=REPLACE_ME
AUTH0_SECRET=REPLACE_ME

# OpenAI (planParser media-plan extraction only — not Ava chat)
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# Ava (Claude) — ANTHROPIC_API_KEY required; AVA_ENGINE=off is an optional kill-switch
ANTHROPIC_API_KEY=REPLACE_ME
# ANTHROPIC_MODEL=claude-sonnet-4-5
# AVA_ENGINE=off

# Xano API bases
XANO_MEDIA_PLANS_BASE_URL=https://xg4h-uyzs-dtex.a2.xano.io/api:RaUx9FOa
XANO_MEDIAPLANS_BASE_URL=https://xg4h-uyzs-dtex.a2.xano.io/api:QVYjoFmM
XANO_CLIENTS_BASE_URL=https://xg4h-uyzs-dtex.a2.xano.io/api:9v_k2NR8
XANO_PUBLISHERS_BASE_URL=REPLACE_WITH_XANO_PUBLISHERS_BASE_URL
XANO_SCOPES_BASE_URL=REPLACE_WITH_XANO_SCOPES_BASE_URL
XANO_MEDIA_DETAILS_BASE_URL=REPLACE_WITH_XANO_MEDIA_DETAILS_BASE_URL
XANO_MEDIA_CONTAINERS_BASE_URL=REPLACE_WITH_XANO_MEDIA_CONTAINERS_BASE_URL
# Optional: api group base for Finance Forecast immutable snapshots (see docs/finance-forecast-snapshots-xano.md)
XANO_FINANCE_FORECAST_SNAPSHOTS_BASE_URL=
# Optional overrides for Xano function paths (defaults: finance_forecast_snapshots_list, finance_forecast_snapshot_lines)
# XANO_FINANCE_FORECAST_SNAPSHOTS_LIST_PATH=
# XANO_FINANCE_FORECAST_SNAPSHOTS_LINES_PATH=
# Xano assistant endpoint (full URL) + optional base
XANO_BASE_URL=REPLACE_WITH_XANO_ASSISTANT_ENDPOINT
# Optional override for the AI assistant endpoint (full URL)
XANO_ASSISTANT_ENDPOINT=

# Auth0 Management API (Machine-to-Machine)
AUTH0_MGMT_CLIENT_ID=REPLACE_ME
AUTH0_MGMT_CLIENT_SECRET=REPLACE_ME
AUTH0_MGMT_AUDIENCE=https://auth.assembledview.com.au/api/v2/
AUTH0_DB_CONNECTION=REPLACE_WITH_DB_CONNECTION_NAME
AUTH0_MGMT_DOMAIN=auth.assembledview.com.au

# Role / client claims (used in the Auth0 Post-Login Action)
AUTH0_ROLE_NAMESPACE=https://assembledview.com/roles
AUTH0_CLIENT_NAMESPACE=https://assembledview.com/client
# If your Auth0 action emits .com.au claims in production, set these to:
# AUTH0_ROLE_NAMESPACE=https://assembledview.com.au/roles
# AUTH0_CLIENT_NAMESPACE=https://assembledview.com.au/client
AUTH0_ROLE_ADMIN_ID=REPLACE_WITH_AUTH0_ADMIN_ROLE_ID
AUTH0_ROLE_CLIENT_ID=REPLACE_WITH_AUTH0_CLIENT_ROLE_ID

# Admin allowlist (comma-separated emails)
ADMIN_EMAIL_ALLOWLIST=luke.fitzpatrick@assembledmedia.com.au

# Email (primary: SendGrid)
SENDGRID_API_KEY=REPLACE_ME
EMAIL_FROM=REPLACE_WITH_FROM_EMAIL
# Optional comma-separated ops/digest recipients (default: luke.fitzpatrick@assembledmedia.com.au)
# OPS_EMAIL_TO=luke.fitzpatrick@assembledmedia.com.au

# Vercel cron shared secret (x-cron-secret or Authorization: Bearer)
CRON_SECRET=REPLACE_ME

# Optional SMTP fallback (used only if SENDGRID_API_KEY is missing)
SMTP_HOST=REPLACE_ME
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_SECURE=false

# Xano user management
XANO_USERS_ENDPOINT=REPLACE_WITH_XANO_USERS_ENDPOINT
XANO_API_KEY=REPLACE_ME

# Vercel Blob (private store, SYD1 — creative assets)
BLOB_READ_WRITE_TOKEN=

# Creative mockup v2 — live page screenshots (ScreenshotOne) + signed frame URLs
# Official names (preferred):
SCREENSHOTONE_ACCESS_KEY=
SCREENSHOTONE_SECRET=
# Also accepted: SCREENSHOT_ACCESS / SCREENSHOT_SECRET
CREATIVE_FRAME_SIGNING_SECRET=

#
# Snowflake
SNOWFLAKE_ACCOUNT=REPLACE_ME
SNOWFLAKE_USERNAME=REPLACE_ME
# PKCS8 PEM with BEGIN/END lines; escape newlines for .env usage
SNOWFLAKE_PRIVATE_KEY=REPLACE_WITH_PKCS8_PRIVATE_KEY
SNOWFLAKE_ROLE=REPLACE_ME
SNOWFLAKE_WAREHOUSE=REPLACE_ME
SNOWFLAKE_DATABASE=ASSEMBLEDVIEW
SNOWFLAKE_SCHEMA=FACEBOOK_ADS

# Vercel recommendations (fail fast under 15s)
# SNOWFLAKE_ACQUIRE_TIMEOUT_MS=7000
# SNOWFLAKE_EXECUTE_TIMEOUT_MS=8000
# SNOWFLAKE_MAX_RETRY_TIME_MS=12000
# SNOWFLAKE_POOL_WARM_SIZE=0






























