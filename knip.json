{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/{page,layout,loading,error,not-found,route,template,default,global-error}.{ts,tsx}",
    "middleware.{ts,tsx}",
    "next.config.{js,mjs,ts}",
    "scripts/**/*.{ts,tsx,js,cjs,mjs}"
  ],
  "project": ["**/*.{ts,tsx}"],
  "ignore": [
    "components/ui/**",
    "lib/finance/forecast/index.ts",
    "lib/finance/forecast/server/index.ts",
    "lib/finance/forecast/snapshot/index.ts",
    "src/ava/index.ts",
    ".agents/**",
    ".worktrees/**",
    ".parked-untracked/**",
    ".digiaudio-expert-origin.tsx"
  ],
  "ignoreDependencies": [
    "autoprefixer",
    "postcss-load-config",
    "@babel/runtime",
    "core-js",
    "eslint-config-next",
    "mammoth",
    "pdf-parse"
  ]
}
