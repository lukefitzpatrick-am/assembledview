# Copy to .env.local and fill in values.

# SendGrid — daily pacing summary emails
SENDGRID_API_KEY=
SENDGRID_PACING_TEMPLATE_ID=
SENDGRID_FROM_EMAIL=pacing@assembledmedia.com.au
SENDGRID_FROM_NAME=AssembledView Pacing

# Vercel Cron / manual trigger: GET or POST /api/pacing/send-daily-summary
# Send header x-cron-secret: <value> or Authorization: Bearer <value>
CRON_SECRET=

# Xano — codex API group (tasks + client notes). Reuses XANO_API_KEY,
# XANO_TIMEOUT_MS, XANO_OVERALL_TIMEOUT_MS from the main app env.
# Required for /tasks — the module fails without this base URL.
XANO_CODEX_BASE_URL=https://xg4h-uyzs-dtex.a2.xano.io/api:codex
